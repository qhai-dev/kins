module(
    name = "kairo",
    version = "1.0.0",
)

bazel_dep(
    name = "rules_go",
    version = "0.61.1",
)
bazel_dep(
    name = "gazelle",
    version = "0.51.3",
)

go_sdk = use_extension(
    "@rules_go//go:extensions.bzl",
    "go_sdk",
)
go_sdk.download(
    version = "1.26.1",
)
use_repo(
    go_sdk,
)

go_deps = use_extension(
    "@gazelle//:extensions.bzl",
    "go_deps",
)
go_deps.from_file(
    go_work = "//:go.work",
)
use_repo(
    go_deps,
)
