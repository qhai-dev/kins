#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/qhai/workspaces/kins/node_modules/.pnpm/webpack@5.91.0_@swc+core@1.3.96_@swc+helpers@0.5.15__esbuild@0.27.7_postcss@8.5.15/node_modules/webpack/node_modules:/home/qhai/workspaces/kins/node_modules/.pnpm/webpack@5.91.0_@swc+core@1.3.96_@swc+helpers@0.5.15__esbuild@0.27.7_postcss@8.5.15/node_modules:/home/qhai/workspaces/kins/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/qhai/workspaces/kins/node_modules/.pnpm/webpack@5.91.0_@swc+core@1.3.96_@swc+helpers@0.5.15__esbuild@0.27.7_postcss@8.5.15/node_modules/webpack/node_modules:/home/qhai/workspaces/kins/node_modules/.pnpm/webpack@5.91.0_@swc+core@1.3.96_@swc+helpers@0.5.15__esbuild@0.27.7_postcss@8.5.15/node_modules:/home/qhai/workspaces/kins/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../webpack/bin/webpack.js" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../webpack/bin/webpack.js" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../webpack/bin/webpack.js" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../webpack/bin/webpack.js" "$@"
else
  exec node  "$basedir/../webpack/bin/webpack.js" "$@"
fi
