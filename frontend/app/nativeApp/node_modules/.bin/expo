#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/qhai-dev/qhai-dev/kairo/node_modules/.pnpm/expo@56.0.8_@babel+core@7.29.7_@expo+dom-webview@56.0.5_@expo+metro-runtime@56.0.13_exp_243cbce6bacbff04fa3133b6b0e40631/node_modules/expo/node_modules:/Users/qhai-dev/qhai-dev/kairo/node_modules/.pnpm/expo@56.0.8_@babel+core@7.29.7_@expo+dom-webview@56.0.5_@expo+metro-runtime@56.0.13_exp_243cbce6bacbff04fa3133b6b0e40631/node_modules:/Users/qhai-dev/qhai-dev/kairo/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/qhai-dev/qhai-dev/kairo/node_modules/.pnpm/expo@56.0.8_@babel+core@7.29.7_@expo+dom-webview@56.0.5_@expo+metro-runtime@56.0.13_exp_243cbce6bacbff04fa3133b6b0e40631/node_modules/expo/node_modules:/Users/qhai-dev/qhai-dev/kairo/node_modules/.pnpm/expo@56.0.8_@babel+core@7.29.7_@expo+dom-webview@56.0.5_@expo+metro-runtime@56.0.13_exp_243cbce6bacbff04fa3133b6b0e40631/node_modules:/Users/qhai-dev/qhai-dev/kairo/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../expo/bin/cli" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../expo/bin/cli" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../expo/bin/cli" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../expo/bin/cli" "$@"
else
  exec node  "$basedir/../expo/bin/cli" "$@"
fi
