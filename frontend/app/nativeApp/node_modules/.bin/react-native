else
  export NODE_PATH="/Users/qhai-dev/qhai-dev/kairo/node_modules/.pnpm/react-native@0.85.3_@babel+core@7.29.7_@react-native+metro-config@0.85.3_@babel+core@7._fb1ef0602a54c26d5abf816cf9a39fc2/node_modules/react-native/node_modules:/Users/qhai-dev/qhai-dev/kairo/node_modules/.pnpm/react-native@0.85.3_@babel+core@7.29.7_@react-native+metro-config@0.85.3_@babel+core@7._fb1ef0602a54c26d5abf816cf9a39fc2/node_modules:/Users/qhai-dev/qhai-dev/kairo/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../react-native/cli.js" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../react-native/cli.js" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../react-native/cli.js" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../react-native/cli.js" "$@"
else
  exec node  "$basedir/../react-native/cli.js" "$@"
fi
